# Generate a strong random string (e.g. openssl rand -base64 32)
PAYLOAD_SECRET=your-secret-here

# Your production URL (set after Vercel deploy)
NEXT_PUBLIC_SERVER_URL=https://your-project.vercel.app

# Neon Postgres connection string
DATABASE_URI=postgres://user:password@host/dbname?sslmode=require

# Cloudflare R2 — from Cloudflare dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET=furniture-media
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
